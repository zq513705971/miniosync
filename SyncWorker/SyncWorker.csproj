<Project Sdk="Microsoft.NET.Sdk" ToolsVersion="15.0">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <AssemblyName>SyncWorker</AssemblyName>
    <RootNamespace>SyncWorker</RootNamespace>
    <!-- 保留原 ProjectGuid: {515c69cc-2136-4407-a475-e918a794f0c1} -->
    <ProjectGuid>{515c69cc-2136-4407-a475-e918a794f0c1}</ProjectGuid>
    <ApplicationIcon>..\app_icon.ico</ApplicationIcon>
    <!--
      .NET 8 SDK 默认禁用了 UseAppHost 反转; 开启让 EXE 文件有 EXE header
      (而非 dll), 与 .NET Framework 行为一致.
    -->
    <UseAppHost>true</UseAppHost>
    <TargetFrameworkVersion>v2.0</TargetFrameworkVersion>
    <FileUpgradeFlags>
    </FileUpgradeFlags>
    <UpgradeBackupLocation>
    </UpgradeBackupLocation>
    <OldToolsVersion>2.0</OldToolsVersion>
  </PropertyGroup>
  <ItemGroup>
    <!-- 引用项目内的公共库 -->
    <ProjectReference Include="..\MinioCommon\MinioCommon.csproj" />
  </ItemGroup>
  <!--
    Minio 包引用已迁移到 MinioCommon, 这里不再引用.
    MinioUploader 类从 MinioCommon 命名空间引入.
  -->
</Project>