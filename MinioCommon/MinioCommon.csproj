<Project Sdk="Microsoft.NET.Sdk" ToolsVersion="15.0">
  <PropertyGroup>
    <!-- 类库, 不含主入口 -->
    <OutputType>Library</OutputType>
    <AssemblyName>MinioCommon</AssemblyName>
    <RootNamespace>MinioCommon</RootNamespace>
    <!-- 保留原 ProjectGuid (从旧 AssemblyInfo.cs): {377ce237-a6cf-4f81-a1c6-b7915803d1a8} -->
    <ProjectGuid>{377ce237-a6cf-4f81-a1c6-b7915803d1a8}</ProjectGuid>
    <TargetFrameworkVersion>v2.0</TargetFrameworkVersion>
    <FileUpgradeFlags>
    </FileUpgradeFlags>
    <UpgradeBackupLocation>
    </UpgradeBackupLocation>
    <OldToolsVersion>2.0</OldToolsVersion>
  </PropertyGroup>
  <!--
    注意: TargetFramework / PlatformTarget / LangVersion / Nullable / DebugType 等
    通用属性由 Directory.Build.props 统一提供, 此处不重复设置.
  -->
  <!--
    包引用: 此项目不再使用 Newtonsoft.Json. 配置加载改为 System.Text.Json + Source Generator
    (见 ConfigFile.cs 的 JsonSerializable 注解).
    NuGet 客户端自动还原 %USERPROFILE%\.nuget\packages\, 不再有 packages\ 目录.

    Minio 7.0.0 在这里引用 — MinioUploader.cs 已迁移到 MinioCommon, 供 MinioSync / SyncWorker /
    FullSync 三个可执行项目共享使用.
  -->
  <ItemGroup>
    <PackageReference Include="Minio" Version="7.0.0" />
  </ItemGroup>
</Project>